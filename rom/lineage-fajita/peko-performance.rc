# peko-performance.rc — Runtime performance tweaks applied once per boot.
# Place at /system/etc/init/peko-performance.rc via Android.bp.

on boot
    # Governor — schedutil by default, performance if persist.peko.governor=performance
    write /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor schedutil
    write /sys/devices/system/cpu/cpu4/cpufreq/scaling_governor schedutil

    # Zram 50% of RAM — cheap compression beats swap on NAND
    swapoff -a
    write /sys/block/zram0/reset 1
    write /sys/block/zram0/disksize 4294967296
    write /sys/block/zram0/comp_algorithm lz4
    mkswap /dev/block/zram0
    swapon /dev/block/zram0 -p 10

    # Minimal IO scheduler for Snapdragon 845 eMMC/UFS
    write /sys/block/sda/queue/scheduler "noop"

    # Skip Doze whitelist for peko binaries (so life loop keeps ticking)
    exec u:r:su:s0 -- /system/bin/cmd deviceidle whitelist +bin.peko-agent
    exec u:r:su:s0 -- /system/bin/cmd deviceidle whitelist +bin.peko-llm-daemon

# When peko.governor prop is set to performance, switch to it (shakedown mode)
on property:persist.peko.governor=performance
    write /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor performance
    write /sys/devices/system/cpu/cpu4/cpufreq/scaling_governor performance

on property:persist.peko.governor=schedutil
    write /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor schedutil
    write /sys/devices/system/cpu/cpu4/cpufreq/scaling_governor schedutil

# LLM daemon service — starts automatically when persist.peko.autostart=1
service peko-llm-daemon /system/bin/peko-llm-daemon \
    --model /data/peko/models/local.gguf \
    --socket @peko-llm
    class main
    user root
    group root input graphics
    capabilities DAC_OVERRIDE
    oom_score_adjust -800
    disabled
    restart_period 5
    restart_limit 3

on property:persist.peko.autostart=1
    # Start daemon first, then agent (agent connects to daemon over UDS)
    start peko-llm-daemon
    setprop sys.peko.start 1
