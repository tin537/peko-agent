<?xml version="1.0" encoding="utf-8"?>
<!--
  Peko SMS shim. A headless priv-app whose only job is to convert a
  broadcast from peko-agent into an SmsManager.sendTextMessage() call.

  Why this exists:
  - The `input`-style shell path (service call isms N ...) requires
    hardcoding Android-version-specific transaction indices, which
    breaks on every OS upgrade.
  - The AT-over-serial path (SmsTool in peko-tools-android) doesn't
    work on OnePlus / Pixel / Samsung devices because RILD owns the
    modem channel exclusively.
  - Using SmsManager via a bundled priv-app is the same path Android's
    own Messages app uses. Stable across versions, survives updates.

  All the declared permissions are "signature|privileged" or
  "privileged" level — i.e. they cannot be granted at runtime on a
  stock install. Grant happens via privapp-permissions-peko.xml at
  /system/etc/permissions/ (shipped alongside the APK in the Magisk
  module). Without that XML, the APK installs but can't send anything.

  Deliberately NO MainActivity: there is nothing for a user to open.
  The package shows up under Settings → Apps → System → Peko SMS
  Shim and is there purely as a permissions carrier for the receiver.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Sending and reading -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.WRITE_SMS"
        tools:ignore="ProtectedPermissions" />

    <!-- MMS filters are required for SMS-role qualification even though
         we don't actually handle MMS; see WapPushDeliverReceiver.kt. -->
    <uses-permission android:name="android.permission.RECEIVE_WAP_PUSH" />
    <uses-permission android:name="android.permission.RECEIVE_MMS" />

    <!-- Picking the right SIM on multi-SIM devices -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />

    <!-- Privileged: allows subscriptionId routing for non-default SMS apps -->
    <uses-permission
        android:name="android.permission.MODIFY_PHONE_STATE"
        tools:ignore="ProtectedPermissions" />

    <!-- Required for posting incoming-SMS notifications once we hold
         the default SMS role. Runtime-granted on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Voice-call recording pipeline.

         PHONE_STATE broadcasts are what CallStateReceiver listens for;
         READ_CALL_LOG gives us the caller number on OFFHOOK transitions
         (EXTRA_INCOMING_NUMBER requires it on Android 13+).

         RECORD_AUDIO is the dangerous runtime perm MediaRecorder checks.
         FOREGROUND_SERVICE + FOREGROUND_SERVICE_MICROPHONE are required
         by Android 13+ for a service that records audio.

         CAPTURE_AUDIO_OUTPUT is signature|privileged — it's the only
         perm that unlocks MediaRecorder.AudioSource.VOICE_CALL, which
         captures both uplink and downlink. Without it, recording
         silently falls back to MIC (only local side audible). Granted
         via privapp-permissions-peko.xml; see service.sh for the
         runtime `pm grant RECORD_AUDIO` step. -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.PROCESS_OUTGOING_CALLS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission
        android:name="android.permission.CAPTURE_AUDIO_OUTPUT"
        tools:ignore="ProtectedPermissions" />

    <application
        android:label="Peko SMS Shim"
        android:description="@string/app_desc"
        android:allowBackup="false"
        android:hasFragileUserData="false"
        android:hardwareAccelerated="false"
        android:directBootAware="true">

        <!-- The only entry point. Explicit component name required because
             implicit broadcasts with custom actions are restricted on
             Android 8+. peko-agent invokes via `am broadcast` with
             extras: id=<uuid>, to=<phone>, body=<text>. (See the
             tool's Rust side in peko-tools-android/src/sms_framework.rs
             for the exact command line.)

             android:permission is set so only callers holding
             SEND_SMS (root shell does, installed apps don't) can
             trigger the receiver — a defence-in-depth layer on top of
             peko-agent's own UID check inside onReceive(). -->
        <receiver
            android:name=".SmsCommandReceiver"
            android:enabled="true"
            android:exported="true"
            android:directBootAware="true"
            android:permission="android.permission.SEND_SMS">
            <intent-filter>
                <action android:name="com.peko.shim.sms.SEND" />
                <action android:name="com.peko.shim.sms.STATUS" />
            </intent-filter>
        </receiver>

        <!-- Receiver for the PendingIntents SmsManager fires when the
             message is actually sent / delivered by the radio. Writes
             the outcome into the same result file so peko's poller
             sees it. -->
        <receiver
            android:name=".SmsResultReceiver"
            android:enabled="true"
            android:exported="false"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="com.peko.shim.sms.RESULT" />
            </intent-filter>
        </receiver>

        <!--  ─── Default-SMS-app role qualification ────────────────────
              The four declarations below are required by
              android.app.role.SMS per RoleController's role.xml. Without
              all four present, `cmd role add-role-holder` silently fails
              and SEND_SMS stays APPLY_RESTRICTION=true, which throws a
              SecurityException at SmsManager.sendTextMessage().

              Functional job: the SmsDeliverReceiver writes incoming SMS
              to content://sms/inbox so the user's stock Messaging app
              keeps showing them. Everything else is stubbed — we only
              want the role for the permission grants it unlocks. -->

        <!-- Activity for ACTION_SENDTO sms:/smsto:. Required for role
             qualification; we finish immediately in onCreate(). -->
        <activity
            android:name=".SendToActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay"
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="android.intent.action.SENDTO" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
            </intent-filter>
        </activity>

        <!-- Incoming SMS. Priority=1 so other receivers in the chain
             don't race us for the (ordered) broadcast. -->
        <receiver
            android:name=".SmsDeliverReceiver"
            android:exported="true"
            android:directBootAware="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="1">
                <action android:name="android.provider.Telephony.SMS_DELIVER" />
            </intent-filter>
        </receiver>

        <!-- MMS (WAP Push). Stubbed. Required for role qualification. -->
        <receiver
            android:name=".WapPushDeliverReceiver"
            android:exported="true"
            android:directBootAware="true"
            android:permission="android.permission.BROADCAST_WAP_PUSH">
            <intent-filter>
                <action android:name="android.provider.Telephony.WAP_PUSH_DELIVER" />
                <data android:mimeType="application/vnd.wap.mms-message" />
            </intent-filter>
        </receiver>

        <!-- Quick-reply service fired from the incoming-call screen.
             Also stubbed; see RespondViaMessageService.kt comment. -->
        <service
            android:name=".RespondViaMessageService"
            android:exported="true"
            android:permission="android.permission.SEND_RESPOND_VIA_MESSAGE">
            <intent-filter>
                <action android:name="android.intent.action.RESPOND_VIA_MESSAGE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
            </intent-filter>
        </service>

        <!-- ─── Voice call recording ─────────────────────────────────
             CallStateReceiver observes phone-call state transitions
             (RINGING → OFFHOOK → IDLE). On OFFHOOK it spins up
             CallRecorderService which plays two consent beeps, starts
             a MediaRecorder against the voice-call audio path, and
             writes an .m4a + metadata .json to the shim's private
             files dir. peko-agent polls that dir for transcription +
             LLM summary. -->
        <receiver
            android:name=".CallStateReceiver"
            android:exported="true"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>
        <!-- Captures the dialed number on outgoing calls. Fires
             strictly before PHONE_STATE=OFFHOOK, so CallStateReceiver
             can pick the target up from the shared companion when
             the recorder service starts. -->
        <receiver
            android:name=".OutgoingCallReceiver"
            android:exported="true"
            android:directBootAware="true"
            android:permission="android.permission.PROCESS_OUTGOING_CALLS">
            <intent-filter>
                <action android:name="android.intent.action.NEW_OUTGOING_CALL" />
            </intent-filter>
        </receiver>
        <service
            android:name=".CallRecorderService"
            android:exported="false"
            android:foregroundServiceType="microphone" />
    </application>
</manifest>
